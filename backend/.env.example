# Copy this file to .env.local and configure your local settings.
# The backend loads ONLY .env.local (not .env).

PORT=5007
NODE_ENV=development

# PostgreSQL
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=signflow_db

# Token lifetimes (seconds)
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
PASSWORD_RESET_TTL=3600
EMAIL_VERIFICATION_TTL=86400

# Required for webhook secret encryption and other app-level crypto (min 32 chars)
APP_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Optional production monitoring
# SENTRY_DSN=https://example.ingest.sentry.io/123

# Frontend URL (used in password-reset emails)
FRONTEND_URL=http://localhost:5177
BASE_URL=http://localhost:5177

# CORS (comma-separated). In development, http://localhost and http://127.0.0.1 are also allowed.
CORS_ORIGIN=http://localhost:5177,http://127.0.0.1:5177

# Application logging (Winston)
LOG_LEVEL=info
APPLICATION_LOG_DB_ENABLED=true
APPLICATION_LOG_DB_LEVEL=info
LOG_SKIP_PATHS=/health,/api/v1/health

# Email (see backend/src/functions/emailconfig.ts)
# EMAIL_SERVICE_TYPE: gmail | office365 | smtp
EMAIL_SERVICE_TYPE=gmail
SENDER_EMAIL_ID=your-email@gmail.com
SENDER_EMAIL_PASSWORD=your-app-password
# Optional CC/BCC on all outbound mail
# CC_EMAIL=['cc1@example.com','cc2@example.com']
# BCC_EMAIL=['bcc@example.com']
# For smtp mode only:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
